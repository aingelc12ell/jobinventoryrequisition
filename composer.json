{
    "name": "gelo/job-inventory-requests",
    "description": "Job & Inventory Request Management System",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "ext-pdo": "*",
        "slim/slim": "^4.15.1",
        "slim/psr7": "^1.8",
        "php-di/php-di": "^7.1.1",
        "php-di/slim-bridge": "^3.4.1",
        "slim/twig-view": "^3.4.1",
        "slim/csrf": "^1.5.1",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.10",
        "phpmailer/phpmailer": "7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": true,
        "sort-packages": true
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "optimize": "composer dump-autoload --optimize --classmap-authoritative"
    }
}
