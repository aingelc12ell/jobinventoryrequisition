{% extends 'layouts/app.twig' %}

{% block title %}Review Request #{{ request.id }}{% endblock %}

{# ── Status label & class mappings ── #}
{% set status_labels = {
    'draft': 'Draft',
    'submitted': 'Submitted',
    'in_review': 'In Review',
    'approved': 'Approved',
    'rejected': 'Rejected',
    'completed': 'Completed',
    'cancelled': 'Cancelled'
} %}

{% set status_classes = {
    'draft': 'bg-secondary',
    'submitted': 'bg-primary',
    'in_review': 'bg-warning text-dark',
    'approved': 'bg-success',
    'rejected': 'bg-danger',
    'completed': 'bg-info',
    'cancelled': 'bg-secondary'
} %}

{% set priority_classes = {
    'low': 'bg-secondary',
    'medium': 'bg-info',
    'high': 'bg-warning text-dark',
    'urgent': 'bg-danger'
} %}

{% block content %}
<div class="container py-4">

    {# ── Page Header ── #}
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h2>Request #{{ request.id }}: {{ request.title }}</h2>
                <div class="d-flex gap-2">
                    <a href="/messages/new?request_id={{ request.id }}&subject={{ ('Re: Request #' ~ request.id ~ ' — ' ~ request.title)|url_encode }}"
                       class="btn btn-outline-info">
                        <i class="fas fa-envelope me-1"></i> Message Submitter
                    </a>
                    <a href="/staff/requests" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Queue
                    </a>
                </div>
            </div>
        </div>
    </div>

    {# ── Three-Column Layout ── #}
    <div class="row g-4">

        {# ══════════════════════════════════════════════════════════════════════
           LEFT COLUMN — Request Details
           ══════════════════════════════════════════════════════════════════════ #}
        <div class="col-lg-6">

            {# ── Details Card ── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Request Details</h5>
                </div>
                <div class="card-body">
                    <p>{{ request.description }}</p>

                    {% if request.type == 'inventory' and request.items is defined and request.items is not empty %}
                        <h6 class="mt-3">Requested Items</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Qty</th>
                                        <th>Unit</th>
                                        <th>Notes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in request.items %}
                                        <tr>
                                            <td>{{ item.name }}</td>
                                            <td>{{ item.quantity }}</td>
                                            <td>{{ item.unit }}</td>
                                            <td>{{ item.notes|default('') }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# ── Attachments Card ── #}
            {% if request.attachments is defined and request.attachments is not empty %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Attachments</h5>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            {% for attachment in request.attachments %}
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        {% if 'pdf' in attachment.mime_type %}
                                            <i class="fas fa-file-pdf text-danger me-2"></i>
                                        {% elseif 'image' in attachment.mime_type %}
                                            <i class="fas fa-file-image text-primary me-2"></i>
                                        {% else %}
                                            <i class="fas fa-file text-secondary me-2"></i>
                                        {% endif %}
                                        <a href="{{ attachment.url }}" target="_blank">{{ attachment.filename }}</a>
                                    </div>
                                    <span class="text-muted small">{{ attachment.size_formatted }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            {% endif %}

        </div>

        {# ══════════════════════════════════════════════════════════════════════
           MIDDLE COLUMN — Actions
           ══════════════════════════════════════════════════════════════════════ #}
        <div class="col-lg-3">

            {# ── Status Actions Card ── #}
            {% if allowed_transitions is defined and allowed_transitions is not empty %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Update Status</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="/staff/requests/{{ request.id }}/status">
                            {{ csrf_fields|raw }}
                            <div class="mb-3">
                                <label for="status-select" class="form-label">Status</label>
                                <select id="status-select" name="status" class="form-select" required>
                                    <option value="">-- Select Status --</option>
                                    {% for transition in allowed_transitions %}
                                        <option value="{{ transition }}">{{ status_labels[transition]|default(transition) }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="status-comment" class="form-label">Comment <span class="text-muted">(optional)</span></label>
                                <textarea id="status-comment" name="comment" class="form-control" rows="3"
                                          placeholder="Add a note about this change..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Update Status</button>
                        </form>
                    </div>
                </div>
            {% endif %}

            {# ── Assignment Card ── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Assignment</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2">
                        <strong>Current:</strong>
                        {% if request.assigned_to_name %}
                            <a href="/profile/{{ request.assigned_to }}" class="text-decoration-none">{{ request.assigned_to_name }}</a>
                        {% else %}
                            <span class="text-muted">Unassigned</span>
                        {% endif %}
                    </p>
                    <form method="POST" action="/staff/requests/{{ request.id }}/assign">
                        {{ csrf_fields|raw }}
                        <div class="mb-3">
                            <label for="assign-select" class="form-label">Assign To</label>
                            <select id="assign-select" name="assigned_to" class="form-select">
                                <option value="">Unassigned</option>
                                {% for staff in staff_list %}
                                    <option value="{{ staff.id }}" {{ request.assigned_to == staff.id ? 'selected' : '' }}>
                                        {{ staff.full_name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <button type="submit" class="btn btn-outline-primary w-100">Assign</button>
                    </form>
                </div>
            </div>

        </div>

        {# ══════════════════════════════════════════════════════════════════════
           RIGHT COLUMN — Info & History
           ══════════════════════════════════════════════════════════════════════ #}
        <div class="col-lg-3">

            {# ── Request Info Card ── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Request Info</h5>
                </div>
                <div class="card-body">
                    <dl class="mb-0">
                        <dt>Type</dt>
                        <dd>
                            {% if request.type == 'job' %}
                                <i class="fas fa-briefcase text-primary"></i> Job
                            {% elseif request.type == 'inventory' %}
                                <i class="fas fa-boxes-stacked text-success"></i> Inventory
                            {% else %}
                                {{ request.type }}
                            {% endif %}
                        </dd>

                        <dt>Status</dt>
                        <dd>
                            <span class="badge {{ status_classes[request.status]|default('bg-secondary') }}">
                                {{ status_labels[request.status]|default(request.status) }}
                            </span>
                        </dd>

                        <dt>Priority</dt>
                        <dd>
                            <span class="badge {{ priority_classes[request.priority]|default('bg-secondary') }}">
                                {{ request.priority|capitalize }}
                            </span>
                        </dd>

                        <dt>Submitted By</dt>
                        <dd>
                            {% if request.submitted_by %}
                                <a href="/profile/{{ request.submitted_by }}" class="text-decoration-none">{{ request.submitter_name }}</a>
                            {% else %}
                                {{ request.submitter_name }}
                            {% endif %}
                        </dd>

                        <dt>Due Date</dt>
                        <dd>
                            {% if request.due_date %}
                                {% if request.due_date < "now"|date("Y-m-d") and request.status not in ['completed', 'cancelled'] %}
                                    <span class="text-danger fw-bold">{{ request.due_date|date("M d, Y") }}</span>
                                {% else %}
                                    {{ request.due_date|date("M d, Y") }}
                                {% endif %}
                            {% else %}
                                <span class="text-muted">&mdash;</span>
                            {% endif %}
                        </dd>

                        <dt>Created</dt>
                        <dd>{{ request.created_at|date("M d, Y") }}</dd>

                        <dt>Updated</dt>
                        <dd>{{ request.updated_at|date("M d, Y") }}</dd>
                    </dl>
                </div>
            </div>

            {# ── Status History Card ── #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Status History</h5>
                </div>
                <div class="card-body">
                    {% if status_history is defined and status_history is not empty %}
                        <div class="timeline">
                            {% for entry in status_history %}
                                <div class="mb-3 border-start border-2 ps-3">
                                    <div class="small">
                                        <i class="fas fa-circle-dot text-primary me-1" style="font-size: 0.6rem;"></i>
                                        <span class="badge {{ status_classes[entry.new_status]|default('bg-secondary') }} me-1">
                                            {{ status_labels[entry.new_status]|default(entry.new_status) }}
                                        </span>
                                        by <strong><a href="/profile/{{ entry.changed_by }}" class="text-decoration-none">{{ entry.changed_by_name }}</a></strong>
                                    </div>
                                    <div class="text-muted small">{{ entry.created_at|date("M d, Y g:ia") }}</div>
                                    {% if entry.comment %}
                                        <div class="text-muted fst-italic small mt-1">{{ entry.comment }}</div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted mb-0">No history yet.</p>
                    {% endif %}
                </div>
            </div>

        </div>

    </div>

</div>
{% endblock %}
