{% extends 'layouts/app.twig' %}

{% block title %}Staff Dashboard — {{ app_name }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">

    {# ── Header ── #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Welcome, {{ user.full_name }}</h2>
            <span class="badge bg-warning text-dark">Staff</span>
        </div>
        <a href="/staff/requests" class="btn btn-primary">
            <i class="fas fa-tasks me-1"></i> Request Queue
        </a>
    </div>

    {# ── Top Stats Row ── #}
    {% set sc = dashboard.status_counts %}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 col-xl">
            <div class="card text-center h-100 border-primary">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-primary">{{ dashboard.pending_count }}</div>
                    <small class="text-muted">Pending Review</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-warning">{{ sc.in_review|default(0) }}</div>
                    <small class="text-muted">In Review</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-success">{{ sc.approved|default(0) }}</div>
                    <small class="text-muted">Approved</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="fs-2 fw-bold text-info">{{ dashboard.avg_turnaround ? dashboard.avg_turnaround ~ 'h' : 'N/A' }}</div>
                    <small class="text-muted">Avg Turnaround</small>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3 col-xl">
            <div class="card text-center h-100 {{ dashboard.inventory_alerts|length > 0 ? 'border-danger' : '' }}">
                <div class="card-body">
                    <div class="fs-2 fw-bold {{ dashboard.inventory_alerts|length > 0 ? 'text-danger' : 'text-muted' }}">{{ dashboard.inventory_alerts|length }}</div>
                    <small class="text-muted">Low Stock Alerts</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        {# ── Left Column ── #}
        <div class="col-lg-8">

            {# Charts Row #}
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-chart-bar me-1"></i> Requests by Priority</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="priorityChart" height="220"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <h6 class="mb-0"><i class="fas fa-chart-pie me-1"></i> Requests by Type</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="typeChart" height="220"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            {# Recent Submissions #}
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-inbox me-1"></i> Recent Submissions</h5>
                    <a href="/staff/requests" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    {% if dashboard.recent_submissions is not empty %}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Title</th>
                                        <th>Submitter</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for req in dashboard.recent_submissions %}
                                        <tr>
                                            <td><a href="/staff/requests/{{ req.id }}">#{{ req.id }}</a></td>
                                            <td>{{ req.title }}</td>
                                            <td>{{ req.submitter_name|default('—') }}</td>
                                            <td>
                                                {% set pc = {'low':'bg-secondary','medium':'bg-info','high':'bg-warning text-dark','urgent':'bg-danger'} %}
                                                <span class="badge {{ pc[req.priority]|default('bg-secondary') }}">{{ req.priority|capitalize }}</span>
                                            </td>
                                            <td>
                                                {% set stc = {'draft':'bg-secondary','submitted':'bg-primary','in_review':'bg-warning text-dark','approved':'bg-success','rejected':'bg-danger','completed':'bg-info','cancelled':'bg-secondary'} %}
                                                <span class="badge {{ stc[req.status]|default('bg-secondary') }}">{{ req.status|replace({'_': ' '})|capitalize }}</span>
                                            </td>
                                            <td><small>{{ req.created_at|date('M d') }}</small></td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-4 text-muted">No submissions yet.</div>
                    {% endif %}
                </div>
            </div>

            {# My Assigned Requests #}
            {% if dashboard.my_assigned is not empty %}
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-user-check me-1"></i> My Assigned Requests</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>#</th>
                                        <th>Title</th>
                                        <th>From</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for req in dashboard.my_assigned %}
                                        <tr>
                                            <td><a href="/staff/requests/{{ req.id }}">#{{ req.id }}</a></td>
                                            <td>{{ req.title }}</td>
                                            <td>{{ req.submitter_name|default('—') }}</td>
                                            <td>
                                                {% set pc = {'low':'bg-secondary','medium':'bg-info','high':'bg-warning text-dark','urgent':'bg-danger'} %}
                                                <span class="badge {{ pc[req.priority]|default('bg-secondary') }}">{{ req.priority|capitalize }}</span>
                                            </td>
                                            <td>
                                                {% set stc = {'draft':'bg-secondary','submitted':'bg-primary','in_review':'bg-warning text-dark','approved':'bg-success','rejected':'bg-danger','completed':'bg-info','cancelled':'bg-secondary'} %}
                                                <span class="badge {{ stc[req.status]|default('bg-secondary') }}">{{ req.status|replace({'_': ' '})|capitalize }}</span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        {# ── Right Sidebar ── #}
        <div class="col-lg-4">

            {# Workload Distribution #}
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-users me-1"></i> Workload Distribution</h6>
                </div>
                <div class="card-body">
                    {% if dashboard.workload_by_assignee is not empty %}
                        {% for entry in dashboard.workload_by_assignee %}
                            <div class="d-flex justify-content-between mb-2">
                                <span>{{ entry.full_name }}</span>
                                <span class="badge bg-primary rounded-pill">{{ entry.count }}</span>
                            </div>
                        {% endfor %}
                    {% else %}
                        <p class="text-muted text-center mb-0">No assignments yet.</p>
                    {% endif %}
                </div>
            </div>

            {# Inventory Alerts #}
            {% if dashboard.inventory_alerts is not empty %}
                <div class="card mb-4 border-danger">
                    <div class="card-header bg-danger text-white">
                        <h6 class="mb-0"><i class="fas fa-exclamation-triangle me-1"></i> Low Stock Alerts</h6>
                    </div>
                    <div class="list-group list-group-flush">
                        {% for item in dashboard.inventory_alerts %}
                            <a href="/staff/inventory/{{ item.id }}" class="list-group-item list-group-item-action list-group-item-warning">
                                <div class="d-flex justify-content-between">
                                    <span>{{ item.name }}</span>
                                    <span class="badge bg-danger">{{ item.current_stock is same as(0) ? '0' : item.current_stock }} left</span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# Messages #}
            <div class="card mb-4">
                <div class="card-body text-center">
                    <div class="fs-3 fw-bold {{ dashboard.unread_messages > 0 ? 'text-danger' : 'text-muted' }}">
                        {{ dashboard.unread_messages }}
                    </div>
                    <small class="text-muted">Unread Messages</small>
                    <div class="mt-2">
                        <a href="/messages" class="btn btn-sm btn-outline-primary">Inbox</a>
                    </div>
                </div>
            </div>

            {# Activity Feed #}
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-history me-1"></i> Recent Activity</h6>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    {% include 'components/activity-feed.twig' with {'activities': dashboard.recent_activity} %}
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Priority bar chart
    var priorityData = {{ dashboard.requests_by_priority|json_encode|raw }};
    var pLabels = [], pData = [];
    var pColors = { 'low': '#6c757d', 'medium': '#0dcaf0', 'high': '#ffc107', 'urgent': '#dc3545' };
    var pBg = [];
    ['urgent', 'high', 'medium', 'low'].forEach(function(p) {
        if (priorityData[p]) {
            pLabels.push(p.charAt(0).toUpperCase() + p.slice(1));
            pData.push(priorityData[p]);
            pBg.push(pColors[p]);
        }
    });
    if (pData.length > 0) {
        new Chart(document.getElementById('priorityChart'), {
            type: 'bar',
            data: { labels: pLabels, datasets: [{ label: 'Requests', data: pData, backgroundColor: pBg }] },
            options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });
    }

    // Type doughnut chart
    var typeData = {{ dashboard.requests_by_type|json_encode|raw }};
    var tLabels = [], tData = [], tBg = [];
    var typeColors = ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6f42c1', '#0dcaf0'];
    var i = 0;
    for (var key in typeData) {
        tLabels.push(key.charAt(0).toUpperCase() + key.slice(1));
        tData.push(typeData[key]);
        tBg.push(typeColors[i % typeColors.length]);
        i++;
    }
    if (tData.length > 0) {
        new Chart(document.getElementById('typeChart'), {
            type: 'doughnut',
            data: { labels: tLabels, datasets: [{ data: tData, backgroundColor: tBg }] },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }
});
</script>
{% endblock %}
