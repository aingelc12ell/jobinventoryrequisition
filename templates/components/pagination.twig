{# ──────────────────────────────────────────────────────────────────────────────
   Pagination Component
   Reusable Bootstrap 5 pagination with ellipsis support.
   Expects:
     - current_page  (int)     The active page number (1-based)
     - total_pages   (int)     Total number of pages
     - base_url      (string)  URL template — page number will be appended as
                               a query parameter, e.g. "/requests" becomes
                               "/requests?page=2"
   Shows at most 5 page numbers at a time, with ellipsis when needed.
   ────────────────────────────────────────────────────────────────────────────── #}

{% if total_pages is defined and total_pages > 1 %}

    {# ── Calculate the visible page window (max 5 pages) ── #}
    {% set max_visible = 5 %}
    {% set half = (max_visible / 2)|round(0, 'floor') %}

    {# Determine start and end of the page window #}
    {% set start_page = current_page - half %}
    {% set end_page   = current_page + half %}

    {# Clamp to valid bounds #}
    {% if start_page < 1 %}
        {% set start_page = 1 %}
        {% set end_page   = max_visible < total_pages ? max_visible : total_pages %}
    {% endif %}

    {% if end_page > total_pages %}
        {% set end_page   = total_pages %}
        {% set raw_start  = total_pages - max_visible + 1 %}
        {% set start_page = raw_start > 1 ? raw_start : 1 %}
    {% endif %}

    {# ── Build the URL helper: appends ?page=N or &page=N ── #}
    {% set separator = '?' in base_url ? '&' : '?' %}

    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mb-0">

            {# ── Previous button ── #}
            <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                <a class="page-link"
                   href="{{ current_page > 1 ? base_url ~ separator ~ 'page=' ~ (current_page - 1) : '#' }}"
                   aria-label="Previous"
                   {% if current_page <= 1 %}tabindex="-1" aria-disabled="true"{% endif %}>
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            {# ── Leading ellipsis ── #}
            {% if start_page > 1 %}
                <li class="page-item">
                    <a class="page-link" href="{{ base_url ~ separator ~ 'page=1' }}">1</a>
                </li>
                {% if start_page > 2 %}
                    <li class="page-item disabled">
                        <span class="page-link">&hellip;</span>
                    </li>
                {% endif %}
            {% endif %}

            {# ── Page numbers ── #}
            {% for page in start_page..end_page %}
                <li class="page-item {{ page == current_page ? 'active' : '' }}">
                    <a class="page-link"
                       href="{{ base_url ~ separator ~ 'page=' ~ page }}"
                       {% if page == current_page %}aria-current="page"{% endif %}>
                        {{ page }}
                    </a>
                </li>
            {% endfor %}

            {# ── Trailing ellipsis ── #}
            {% if end_page < total_pages %}
                {% if end_page < total_pages - 1 %}
                    <li class="page-item disabled">
                        <span class="page-link">&hellip;</span>
                    </li>
                {% endif %}
                <li class="page-item">
                    <a class="page-link" href="{{ base_url ~ separator ~ 'page=' ~ total_pages }}">{{ total_pages }}</a>
                </li>
            {% endif %}

            {# ── Next button ── #}
            <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                <a class="page-link"
                   href="{{ current_page < total_pages ? base_url ~ separator ~ 'page=' ~ (current_page + 1) : '#' }}"
                   aria-label="Next"
                   {% if current_page >= total_pages %}tabindex="-1" aria-disabled="true"{% endif %}>
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>

        </ul>
    </nav>

{% endif %}
