{% extends 'layouts/app.twig' %}

{% block title %}Server Error — {{ app_name }}{% endblock %}

{% block content %}
<div class="container d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="display-1 text-danger fw-bold mb-3">500</div>
        <h2 class="mb-3">Something Went Wrong</h2>
        <p class="text-muted mb-4">An unexpected error occurred. Our team has been notified.</p>
        <div class="d-flex gap-2 justify-content-center">
            <a href="/dashboard" class="btn btn-primary">
                <i class="fas fa-home me-1"></i> Dashboard
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Go Back
            </a>
        </div>
    </div>
</div>
{% endblock %}
