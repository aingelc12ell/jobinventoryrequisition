<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Your Email</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f4f4f7; font-family: Arial, Helvetica, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f4f4f7;">
        <tr>
            <td align="center" style="padding: 40px 0;">
                <table role="presentation" width="600" cellspacing="0" cellpadding="0" style="background-color: #ffffff; border-radius: 8px; overflow: hidden;">
                    <!-- Header -->
                    <tr>
                        <td style="background-color: #0d6efd; padding: 30px; text-align: center;">
                            <h1 style="margin: 0; color: #ffffff; font-size: 24px;">Job &amp; Inventory Request System</h1>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 40px 30px;">
                            <p style="margin: 0 0 16px; font-size: 16px; color: #333333;">Hi {{ name }},</p>

                            <p style="margin: 0 0 24px; font-size: 16px; color: #333333;">Please verify your email by clicking the button below.</p>

                            <table role="presentation" cellspacing="0" cellpadding="0" style="margin: 0 auto 24px;">
                                <tr>
                                    <td style="border-radius: 6px; background-color: #0d6efd;">
                                        <a href="{{ verification_url }}"
                                           style="display: inline-block; padding: 14px 32px; font-size: 16px; color: #ffffff; text-decoration: none; font-weight: bold;">
                                            Verify Email Address
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0 0 16px; font-size: 14px; color: #666666;">This link expires in 24 hours.</p>

                            <p style="margin: 0; font-size: 14px; color: #666666;">If you're having trouble clicking the button, copy and paste the following URL into your browser:</p>
                            <p style="margin: 8px 0 0; font-size: 13px; color: #0d6efd; word-break: break-all;">{{ verification_url }}</p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="padding: 20px 30px; background-color: #f4f4f7; border-top: 1px solid #e0e0e0;">
                            <p style="margin: 0; font-size: 13px; color: #999999; text-align: center;">
                                If you didn't create this account, ignore this email.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
