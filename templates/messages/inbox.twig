{% extends 'layouts/app.twig' %}

{% block title %}Messages — {{ app_name }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-envelope me-2"></i>Messages</h2>
        <a href="/messages/new" class="btn btn-primary">
            <i class="fas fa-pen me-1"></i> New Conversation
        </a>
    </div>

    {% if conversations is empty %}
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                <p class="text-muted mb-0">Your inbox is empty.</p>
                <a href="/messages/new" class="btn btn-outline-primary mt-3">Start a conversation</a>
            </div>
        </div>
    {% else %}
        <div class="card">
            <div class="list-group list-group-flush">
                {% for conv in conversations %}
                    <a href="/messages/{{ conv.id }}"
                       class="list-group-item list-group-item-action {{ conv.unread_count > 0 ? 'list-group-item-light' : '' }}">
                        <div class="d-flex w-100 justify-content-between align-items-start">
                            <div class="flex-grow-1 me-3">
                                <div class="d-flex align-items-center mb-1">
                                    {% if conv.unread_count > 0 %}
                                        <span class="badge bg-primary rounded-pill me-2">{{ conv.unread_count }}</span>
                                    {% endif %}
                                    <h6 class="mb-0 {{ conv.unread_count > 0 ? 'fw-bold' : '' }}">
                                        {{ conv.subject }}
                                    </h6>
                                    {% if conv.request_id %}
                                        <span class="badge bg-info ms-2" title="Linked to request #{{ conv.request_id }}">
                                            <i class="fas fa-link me-1"></i>{{ conv.request_title|default('Request #' ~ conv.request_id) }}
                                        </span>
                                    {% endif %}
                                </div>
                                {% if conv.last_message_body %}
                                    <p class="mb-0 text-muted small text-truncate" style="max-width: 600px;">
                                        <strong>{{ conv.last_message_sender|default('Unknown') }}:</strong>
                                        {{ conv.last_message_body|length > 100 ? conv.last_message_body|slice(0, 100) ~ '...' : conv.last_message_body }}
                                    </p>
                                {% endif %}
                            </div>
                            <small class="text-muted text-nowrap">
                                {{ conv.last_message_at|default(conv.updated_at)|date('M d, Y g:i A') }}
                            </small>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>

        {# Pagination #}
        {% if total_pages > 1 %}
            <nav class="mt-4" aria-label="Inbox pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item {{ page <= 1 ? 'disabled' : '' }}">
                        <a class="page-link" href="/messages?page={{ page - 1 }}">Previous</a>
                    </li>
                    {% for p in 1..total_pages %}
                        {% if p >= page - 2 and p <= page + 2 %}
                            <li class="page-item {{ p == page ? 'active' : '' }}">
                                <a class="page-link" href="/messages?page={{ p }}">{{ p }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                    <li class="page-item {{ page >= total_pages ? 'disabled' : '' }}">
                        <a class="page-link" href="/messages?page={{ page + 1 }}">Next</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
