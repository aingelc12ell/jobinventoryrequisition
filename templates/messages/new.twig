{% extends 'layouts/app.twig' %}

{% block title %}New Conversation — {{ app_name }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="mb-4">
        <a href="/messages" class="text-decoration-none text-muted">
            <i class="fas fa-arrow-left me-1"></i> Back to Inbox
        </a>
        <h2 class="mt-2"><i class="fas fa-pen me-2"></i>New Conversation</h2>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" action="/messages">
                {{ csrf_fields|raw }}

                {# Recipients #}
                <div class="mb-3">
                    <label for="recipients" class="form-label">To <span class="text-danger">*</span></label>
                    <select name="recipients[]" id="recipients" class="form-select" multiple required
                            size="{{ recipients|length > 6 ? 6 : recipients|length }}">
                        {% for recipient in recipients %}
                            <option value="{{ recipient.id }}">
                                {{ recipient.full_name }} ({{ recipient.role|capitalize }})
                                {% if recipient.email is defined %} — {{ recipient.email }}{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                    <div class="form-text">Hold Ctrl/Cmd to select multiple recipients.</div>
                </div>

                {# Subject #}
                <div class="mb-3">
                    <label for="subject" class="form-label">Subject <span class="text-danger">*</span></label>
                    <input type="text" name="subject" id="subject" class="form-control"
                           value="{{ old.subject|default(prefill_subject) }}"
                           placeholder="Enter conversation subject" required maxlength="255">
                </div>

                {# Linked Request (optional) #}
                <div class="mb-3">
                    <label for="request_id" class="form-label">Linked Request (optional)</label>
                    <input type="number" name="request_id" id="request_id" class="form-control"
                           value="{{ old.request_id|default(prefill_request_id) }}"
                           placeholder="Request ID (e.g., 42)" min="1">
                    <div class="form-text">Link this conversation to a specific request for context.</div>
                </div>

                {# Message body #}
                <div class="mb-3">
                    <label for="body" class="form-label">Message <span class="text-danger">*</span></label>
                    <textarea name="body" id="body" class="form-control" rows="6"
                              placeholder="Type your message..." required>{{ old.body|default('') }}</textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-1"></i> Send Message
                    </button>
                    <a href="/messages" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
