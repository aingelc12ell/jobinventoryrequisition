{% extends 'layouts/app.twig' %}

{% block title %}Audit Logs — {{ app_name }}{% endblock %}

{% block content %}
<div class="container-fluid py-4">

    <h2 class="mb-4"><i class="fas fa-clipboard-list me-2"></i>Audit Logs</h2>

    {# ── Filters ── #}
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" action="/admin/audit-logs" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Action</label>
                    <select name="action" class="form-select">
                        <option value="">All Actions</option>
                        {% set actions = [
                            'user.created', 'user.updated', 'user.deactivated', 'user.activated',
                            'user.login', 'user.registered',
                            'request.created', 'request.submitted', 'request.updated',
                            'request.status_changed', 'request.cancelled', 'request.assigned',
                            'inventory.created', 'inventory.updated', 'inventory.adjusted',
                            'settings.updated'
                        ] %}
                        {% for action in actions %}
                            <option value="{{ action }}" {{ filters.action|default('') == action ? 'selected' : '' }}>{{ action }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Entity Type</label>
                    <select name="entity_type" class="form-select">
                        <option value="">All Types</option>
                        <option value="user" {{ filters.entity_type|default('') == 'user' ? 'selected' : '' }}>User</option>
                        <option value="request" {{ filters.entity_type|default('') == 'request' ? 'selected' : '' }}>Request</option>
                        <option value="inventory" {{ filters.entity_type|default('') == 'inventory' ? 'selected' : '' }}>Inventory</option>
                        <option value="settings" {{ filters.entity_type|default('') == 'settings' ? 'selected' : '' }}>Settings</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">User ID</label>
                    <input type="number" name="user_id" class="form-control" placeholder="User ID"
                           value="{{ filters.user_id|default('') }}" min="1">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Date From</label>
                    <input type="date" name="date_from" class="form-control"
                           value="{{ filters.date_from|default('') }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Date To</label>
                    <input type="date" name="date_to" class="form-control"
                           value="{{ filters.date_to|default('') }}">
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fas fa-search me-1"></i> Filter
                    </button>
                    <a href="/admin/audit-logs" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    {# ── Log Table ── #}
    <div class="card">
        <div class="card-header">
            <small class="text-muted">{{ total }} log entries</small>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>IP Address</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in logs %}
                            <tr>
                                <td><small class="text-muted">{{ log.id }}</small></td>
                                <td><small>{{ log.created_at|date('M d, Y g:i:s A') }}</small></td>
                                <td>
                                    {% if log.user_id %}
                                        <a href="/admin/users/{{ log.user_id }}/edit">#{{ log.user_id }}</a>
                                    {% else %}
                                        <span class="text-muted">System</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% set action_colors = {
                                        'created': 'text-success', 'submitted': 'text-primary',
                                        'updated': 'text-info', 'status_changed': 'text-warning',
                                        'cancelled': 'text-danger', 'deactivated': 'text-danger',
                                        'activated': 'text-success', 'assigned': 'text-info',
                                        'login': 'text-muted', 'registered': 'text-success'
                                    } %}
                                    {% set action_suffix = log.action|split('.')|last %}
                                    <span class="{{ action_colors[action_suffix]|default('') }}">
                                        <code>{{ log.action }}</code>
                                    </span>
                                </td>
                                <td>
                                    {% if log.entity_type %}
                                        <span class="badge bg-secondary">{{ log.entity_type }}</span>
                                        {% if log.entity_id %}#{{ log.entity_id }}{% endif %}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td><small class="text-muted">{{ log.ip_address|default('—') }}</small></td>
                                <td>
                                    {% if log.old_values or log.new_values %}
                                        <button class="btn btn-sm btn-outline-secondary"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#details-{{ log.id }}">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                            {% if log.old_values or log.new_values %}
                                <tr class="collapse" id="details-{{ log.id }}">
                                    <td colspan="7" class="bg-light">
                                        <div class="row">
                                            {% if log.old_values %}
                                                <div class="col-md-6">
                                                    <strong class="text-danger">Old Values:</strong>
                                                    <pre class="mb-0 small text-dark">{{ log.old_values }}</pre>
                                                </div>
                                            {% endif %}
                                            {% if log.new_values %}
                                                <div class="col-md-6">
                                                    <strong class="text-success">New Values:</strong>
                                                    <pre class="mb-0 small text-dark">{{ log.new_values }}</pre>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endif %}
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No audit log entries found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ── Pagination ── #}
    {% if total_pages > 1 %}
        {% set base_url = '/admin/audit-logs?' %}
        {% for key, val in filters %}
            {% set base_url = base_url ~ key ~ '=' ~ val|url_encode ~ '&' %}
        {% endfor %}
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {{ current_page <= 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ base_url }}page={{ current_page - 1 }}">Previous</a>
                </li>
                {% for p in 1..total_pages %}
                    {% if p >= current_page - 2 and p <= current_page + 2 %}
                        <li class="page-item {{ p == current_page ? 'active' : '' }}">
                            <a class="page-link" href="{{ base_url }}page={{ p }}">{{ p }}</a>
                        </li>
                    {% endif %}
                {% endfor %}
                <li class="page-item {{ current_page >= total_pages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ base_url }}page={{ current_page + 1 }}">Next</a>
                </li>
            </ul>
        </nav>
    {% endif %}
</div>
{% endblock %}
