{% extends 'layouts/app.twig' %}

{% block title %}{{ is_own_profile ? 'My Profile' : profile_user.full_name }} — {{ app_name }}{% endblock %}

{% block content %}
<div class="container py-4">

    {# -- Page Header -- #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fas fa-id-badge me-2"></i>
            {{ is_own_profile ? 'My Profile' : profile_user.full_name }}
        </h2>
        <a href="/dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Dashboard
        </a>
    </div>

    <div class="row g-4">

        {# ── Left Column — User Details ── #}
        <div class="col-lg-5">

            {# -- Profile Card -- #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">User Information</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white"
                             style="width:80px;height:80px;font-size:2rem;">
                            {{ profile_user.full_name|first|upper }}
                        </div>
                        <h4 class="mt-3 mb-1">{{ profile_user.full_name }}</h4>
                        {% set role_class = {'admin':'bg-danger','staff':'bg-warning text-dark','personnel':'bg-info'} %}
                        <span class="badge {{ role_class[profile_user.role]|default('bg-secondary') }}">{{ profile_user.role|capitalize }}</span>
                        {% if profile_user.is_active %}
                            <span class="badge bg-success ms-1">Active</span>
                        {% else %}
                            <span class="badge bg-secondary ms-1">Inactive</span>
                        {% endif %}
                    </div>

                    <dl class="mb-0">
                        <dt>Email</dt>
                        <dd>
                            {{ profile_user.email }}
                            {% if profile_user.email_verified_at %}
                                <i class="fas fa-check-circle text-success ms-1" title="Verified on {{ profile_user.email_verified_at|date('M d, Y') }}"></i>
                            {% else %}
                                <span class="badge bg-warning text-dark ms-1">Unverified</span>
                            {% endif %}
                        </dd>

                        <dt>Two-Factor Authentication</dt>
                        <dd>
                            {% if profile_user.two_factor_enabled %}
                                <i class="fas fa-shield-alt text-success me-1"></i> Enabled
                            {% else %}
                                <i class="fas fa-shield-alt text-muted me-1"></i> Disabled
                            {% endif %}
                        </dd>

                        <dt>Last Login</dt>
                        <dd>{{ profile_user.last_login_at ? profile_user.last_login_at|date('M d, Y g:i A') : 'Never' }}</dd>

                        <dt>Member Since</dt>
                        <dd>{{ profile_user.created_at|date('M d, Y') }}</dd>

                        <dt>Last Updated</dt>
                        <dd>{{ profile_user.updated_at|date('M d, Y') }}</dd>
                    </dl>
                </div>
                {% if is_own_profile and user.role == 'admin' %}
                    <div class="card-footer text-end">
                        <a href="/admin/users/{{ profile_user.id }}/edit" class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-edit me-1"></i> Edit Profile
                        </a>
                    </div>
                {% endif %}
            </div>

        </div>

        {# ── Right Column — Activity Logs ── #}
        <div class="col-lg-7">

            {% if show_logs and logs is defined and logs is not empty %}
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="fas fa-history me-1"></i> Recent Activity</h5>
                        {% if user.role == 'admin' %}
                            <a href="/admin/audit-logs?user_id={{ profile_user.id }}" class="btn btn-sm btn-outline-secondary">
                                View All Logs
                            </a>
                        {% endif %}
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Timestamp</th>
                                        <th>Action</th>
                                        <th>Entity</th>
                                        <th>Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for log in logs %}
                                        <tr>
                                            <td><small>{{ log.created_at|date('M d, Y g:i A') }}</small></td>
                                            <td>
                                                {% set action_colors = {
                                                    'created': 'text-success', 'submitted': 'text-primary',
                                                    'updated': 'text-info', 'status_changed': 'text-warning',
                                                    'cancelled': 'text-danger', 'deactivated': 'text-danger',
                                                    'activated': 'text-success', 'assigned': 'text-info',
                                                    'login': 'text-muted', 'registered': 'text-success',
                                                    'adjusted': 'text-warning', 'item_created': 'text-success'
                                                } %}
                                                {% set action_suffix = log.action|split('.')|last %}
                                                <span class="{{ action_colors[action_suffix]|default('') }}">
                                                    <code class="small">{{ log.action }}</code>
                                                </span>
                                            </td>
                                            <td>
                                                {% if log.entity_type %}
                                                    <span class="badge bg-secondary">{{ log.entity_type }}</span>
                                                    {% if log.entity_id %}#{{ log.entity_id }}{% endif %}
                                                {% else %}
                                                    <span class="text-muted">&mdash;</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if log.old_values or log.new_values %}
                                                    <button class="btn btn-sm btn-outline-secondary py-0"
                                                            type="button"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#profile-log-{{ log.id }}">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                {% endif %}
                                            </td>
                                        </tr>
                                        {% if log.old_values or log.new_values %}
                                            <tr class="collapse" id="profile-log-{{ log.id }}">
                                                <td colspan="4" class="bg-light">
                                                    <div class="row small">
                                                        {% if log.old_values %}
                                                            <div class="col-md-6">
                                                                <strong class="text-danger">Old:</strong>
                                                                <pre class="mb-0 text-dark">{{ log.old_values }}</pre>
                                                            </div>
                                                        {% endif %}
                                                        {% if log.new_values %}
                                                            <div class="col-md-6">
                                                                <strong class="text-success">New:</strong>
                                                                <pre class="mb-0 text-dark">{{ log.new_values }}</pre>
                                                            </div>
                                                        {% endif %}
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endif %}
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% elseif show_logs %}
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-history me-1"></i> Recent Activity</h5>
                    </div>
                    <div class="card-body text-center text-muted py-4">
                        No activity logged yet.
                    </div>
                </div>
            {% else %}
                {# Staff viewing another user — no logs shown #}
                <div class="card">
                    <div class="card-body text-center text-muted py-4">
                        <i class="fas fa-lock me-2"></i>
                        Activity logs are only visible on your own profile.
                    </div>
                </div>
            {% endif %}

        </div>

    </div>
</div>
{% endblock %}
