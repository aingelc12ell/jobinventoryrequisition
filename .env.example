# Application
APP_NAME="Job & Inventory Request System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_SECRET=change-this-to-a-random-64-char-string

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=jobinventoryrequests
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4                       # Character set for the connection
DB_COLLATION=utf8mb4_general_ci          # Collation (use utf8mb4_unicode_ci for MySQL < 8.0)

# Database SSL (optional — for encrypted connections to MySQL)
DB_SSL_ENABLED=false
DB_SSL_CA=                               # Path to CA certificate (e.g. /etc/ssl/certs/ca.pem)
DB_SSL_CERT=                             # Path to client certificate (mutual TLS only)
DB_SSL_KEY=                              # Path to client private key (mutual TLS only)
DB_SSL_VERIFY=true                       # Verify server certificate (set false for self-signed)

# Mail
MAIL_DRIVER=smtp                     # smtp | sendgrid
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Job & Inventory System"

# SMTP settings (when MAIL_DRIVER=smtp)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls

# SendGrid settings (when MAIL_DRIVER=sendgrid)
SENDGRID_API_KEY=

# Session
SESSION_LIFETIME=1800
SESSION_NAME=jir_session
